<!DOCTYPE html>
<html>
<head>

<title>NAZ Cafe Dashboard</title>

<style>

body{
background:#0f172a;
color:white;
font-family:Arial;
margin:0;
padding:40px;
}

h1{
margin-bottom:30px;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fill,200px);
gap:20px;
}

.card{
background:#1e293b;
padding:20px;
border-radius:10px;
text-align:center;
transition:0.2s;
}

.card:hover{
transform:scale(1.05);
background:#334155;
}

.card img{
width:64px;
height:64px;
border-radius:50%;
}

a{
color:white;
text-decoration:none;
}

</style>

</head>

<body>

<h1>Welcome <%= user.username %></h1>

<div class="grid">

<% guilds.forEach(g => { %>

<a href="/server/<%= g.id %>">

<div class="card">

<img src="https://cdn.discordapp.com/icons/<%= g.id %>/<%= g.icon %>.png">

<h3><%= g.name %></h3>

</div>

</a>

<% }) %>

</div>

</body>
</html>
